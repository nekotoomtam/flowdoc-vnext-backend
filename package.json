{
  "name": "flowdoc-vnext-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Backend service boundary for FlowDoc vNext.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "check": "npm run type-check && npm run test && npm run build",
    "pdf-export-local:env": "tsx src/localPdfExport/pdfExportLocalEnv.ts",
    "pdf-export-local:up": "docker compose --env-file .env.local -f docker-compose.pdf-export-local.yml up -d --wait",
    "pdf-export-local:migrate": "tsx --env-file=.env.local src/localPdfExport/pdfExportLocalMigrate.ts",
    "pdf-export-local:http": "tsx --env-file=.env.local src/localPdfExport/pdfExportLocalHttpCommand.ts",
    "pdf-export-local:worker": "tsx --env-file=.env.local src/localPdfExport/pdfExportLocalWorkerCommand.ts",
    "pdf-export-local:test:portable": "tsx src/localPdfExport/pdfExportLocalPortableEvidence.ts",
    "pdf-export-realdoc-e4:verify": "tsx src/localPdfExport/pdfExportRealdocE4Evidence.ts",
    "pdf-export-realdoc-e56:http": "tsx src/localPdfExport/pdfExportRealdocE56HttpCommand.ts",
    "pdf-export-realdoc-e56:verify": "tsx src/localPdfExport/pdfExportRealdocE56Evidence.ts",
    "pdf-export-realdoc-e57:http": "tsx src/localPdfExport/pdfExportRealdocE57HttpCommand.ts",
    "pdf-export-realdoc-e57:verify": "tsx src/localPdfExport/pdfExportRealdocE57Evidence.ts",
    "pdf-export-local:down": "docker compose --env-file .env.local -f docker-compose.pdf-export-local.yml down",
    "pdf-export-local:reset": "tsx --env-file=.env.local src/localPdfExport/pdfExportLocalReset.ts --confirm-reset-local"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@flowdoc/pdf-renderer-pilot": "file:../flowdoc-vnext-core/packages/pdf-renderer-pilot",
    "@flowdoc/vnext-core": "file:../flowdoc-vnext-core",
    "pg": "^8.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "embedded-postgres": "^17.10.0-beta.17",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
